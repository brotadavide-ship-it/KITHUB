<style>

body{
margin:0;
font-family:Arial, sans-serif;
background:#0D0D0D;
color:white;
}

header{
position:fixed;
top:0;
width:100%;
background:#0D0D0D;
padding:15px;
display:flex;
justify-content:space-between;
align-items:center;
border-bottom:1px solid #222;
z-index:1000;
}

.logo{
font-size:24px;
font-weight:bold;
color:#1DB954;
}

nav a{
margin:0 12px;
color:white;
text-decoration:none;
font-size:14px;
}

.hero{
margin-top:80px;
text-align:center;
padding:80px 20px;
background:linear-gradient(#0D0D0D,#1a1a1a);
}

.hero h1{
font-size:42px;
}

.hero p{
font-size:18px;
color:#ccc;
}

.btn{
display:inline-block;
margin:10px;
padding:12px 25px;
background:#1DB954;
color:white;
border-radius:6px;
text-decoration:none;
}

.section{
padding:60px 10%;
}

.section h2{
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
}

.card{
background:#1a1a1a;
border-radius:10px;
padding:15px;
transition:0.3s;
}

.card:hover{
transform:scale(1.03);
}

.card img{
width:100%;
border-radius:8px;
}

.price{
color:#1DB954;
font-weight:bold;
}

.badge{
background:gold;
color:black;
padding:3px 6px;
font-size:12px;
border-radius:4px;
}

footer{
background:black;
padding:40px;
text-align:center;
margin-top:40px;
}

input{
padding:10px;
border-radius:5px;
border:none;
}

</style>
</head>

